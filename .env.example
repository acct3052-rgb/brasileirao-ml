# ── football-data.org ─────────────────────────────────
FOOTBALL_DATA_API_KEY=sua_football_data_key_aqui

# ── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=sua_supabase_service_role_key_aqui

# ── Google Cloud (Base dos Dados / BigQuery) ───────────
# Crie um projeto em console.cloud.google.com
# Ative a BigQuery API
# Crie uma Service Account e baixe o JSON de credenciais
GCP_PROJECT_ID=seu-projeto-gcp-aqui
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/credenciais.json
# No Railway: cole o conteúdo JSON como string na variável abaixo
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ── Segurança da API ───────────────────────────────────
ADMIN_TOKEN=gere_um_token_seguro_aqui

# ── The Odds API ──────────────────────────────────────
ODDS_API_KEY=sua_odds_api_key_aqui

# ── API-Football (RapidAPI) ────────────────────────────
# Obter em: https://rapidapi.com/api-sports/api/api-football
# Free: 100 req/dia | Pro: 7500 req/dia
API_FOOTBALL_KEY=sua_rapidapi_key_aqui

# ── Telegram Alerts ───────────────────────────────────
# Bot: https://t.me/BotFather | Chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
TELEGRAM_CHAT_ID=-1001234567890

# ── Base URL da API (usado pelo cron_pipeline.py) ──────
API_BASE_URL=http://localhost:8000

# ── Configurações opcionais ────────────────────────────
PORT=8000
